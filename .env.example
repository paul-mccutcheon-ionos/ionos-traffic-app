# IONOS Traffic Billing Tool — environment configuration
# Copy this file to .env and fill in your credentials.
# .env is never committed to version control.

# IONOS Cloud API bearer token (from the IONOS DCD or API key management)
IONOS_API_TOKEN=

# IONOS Contract ID (pre-fills the Contract ID field in the UI)
IONOS_CONTRACT_ID=

# IONOS Object Storage S3 credentials (used for Flow Logs bucket access)
IONOS_S3_ACCESS_KEY=
IONOS_S3_SECRET_KEY=

# Optional: password-protect credential auto-fill in the UI.
# Set AUTH_CONTRACT_ID to your contract ID (used as the username prompt).
# Set AUTH_PASSWORD_HASH to a bcrypt hash of your chosen password.
# Generate with: node -e "require('bcryptjs').hash('yourpassword',10).then(h=>console.log(h))"
# Leave both blank to disable password protection.
AUTH_CONTRACT_ID=
AUTH_PASSWORD_HASH=
